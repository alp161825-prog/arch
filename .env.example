# Frontend points to your own backend proxy. Do not put DeepSeek secrets in VITE_* variables for production.
VITE_DEEPSEEK_PROXY_PATH=/api/deepseek/chat
VITE_DEEPSEEK_MODEL=deepseek-chat
VITE_AMAP_KEY=your_amap_key_here
VITE_AMAP_SECURITY_JS_CODE=your_amap_security_js_code_here

# Server-side only
DEEPSEEK_API_KEY=your_server_side_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
OFFICIAL_PROXY_TARGETS=mct-holiday-bulletin,ncha-museum
